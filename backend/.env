# ── MongoDB Connection ──────────────────────────────────────────────
# Option A: Local MongoDB (install MongoDB Community on your PC)
MONGO_URI=mongodb://localhost:27017/cartora

# Option B: MongoDB Atlas (free cloud DB — recommended)
# 1. Go to https://cloud.mongodb.com → create free cluster
# 2. Click Connect → Drivers → copy your connection string
# 3. Replace the line above with your Atlas URI, e.g.:
# MONGO_URI=mongodb+srv://yourUser:yourPassword@cluster0.abc12.mongodb.net/cartora

